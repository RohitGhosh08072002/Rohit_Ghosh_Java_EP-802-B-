<div class="text-center mb-4">
    <p style="color: #94a3b8; font-size: 0.95rem;"><i class="fas fa-chart-bar mr-2"></i>Real-time analytics and complaint management</p>
</div>

<div class="row mb-4">
    <div class="col-md-3 mb-3">
        <div class="stat-card bg-blue-accent">
            <h5 class="stat-card-title">Total Complaints</h5>
            <h2 class="stat-card-value">{{stats.total}}</h2>
            <i class="fas fa-chart-bar stat-card-icon"></i>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="stat-card bg-green-accent">
            <h5 class="stat-card-title">Resolved</h5>
            <h2 class="stat-card-value">{{stats.resolved}}</h2>
            <i class="fas fa-map-marker-alt stat-card-icon"></i>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="stat-card bg-purple-accent">
            <h5 class="stat-card-title">Pending Tasks</h5>
            <h2 class="stat-card-value">{{stats.pending}}</h2>
            <i class="fas fa-folder stat-card-icon"></i>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="stat-card bg-orange-accent">
            <h5 class="stat-card-title">Success Rate</h5>
            <h2 class="stat-card-value">{{stats.successPercentage}}%</h2>
            <i class="fas fa-bolt stat-card-icon"></i>
        </div>
    </div>
</div>

<div class="row mb-5">
    <!-- Chart 1 -->
    <div class="col-md-6 mb-4">
        <div class="chart-panel h-100">
            <h4 class="chart-panel-title">
                <span class="icon" style="color: #60a5fa;"><i class="fas fa-square"></i></span>
                Complaints Trend (Distribution)
            </h4>
            <div style="height: 300px;">
                <canvas id="complaintsChart"></canvas>
            </div>
        </div>
    </div>
    <!-- Chart 2 -->
    <div class="col-md-6 mb-4">
        <div class="chart-panel h-100">
            <h4 class="chart-panel-title">
                <span class="icon" style="color: #a855f7;"><i class="fas fa-folder"></i></span>
                Issue Type Distribution
            </h4>
            <div style="height: 300px;">
                <canvas id="barChart"></canvas>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    document.addEventListener("DOMContentLoaded", function() {
        Chart.defaults.color = '#94a3b8';
        Chart.defaults.borderColor = '#334155';

        var doughnutCtx = document.getElementById('complaintsChart').getContext('2d');
        var myDoughnutChart = new Chart(doughnutCtx, {
            type: 'doughnut',
            data: {
                labels: ['Resolved', 'Pending'],
                datasets: [{
                    data: [{{stats.resolved}}, {{stats.pending}}],
                    backgroundColor: [
                        '#22c55e', 
                        '#f97316'  
                    ],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: { padding: 20 }
                    }
                }
            }
        });

        var barCtx = document.getElementById('barChart').getContext('2d');
        var myBarChart = new Chart(barCtx, {
            type: 'bar',
            data: {
                labels: ['Volume'],
                datasets: [
                    {
                        label: 'Total Complaints',
                        data: [{{stats.total}}],
                        backgroundColor: '#a855f7',
                        barPercentage: 0.6
                    },
                    {
                        label: 'Resolved',
                        data: [{{stats.resolved}}],
                        backgroundColor: '#8b5cf6',
                        barPercentage: 0.6
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    y: {
                        beginAtZero: true
                    },
                    x: {
                        grid: { display: false }
                    }
                },
                plugins: {
                    legend: {
                        position: 'bottom'
                    }
                }
            }
        });
    });
</script>